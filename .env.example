# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session
SESSION_SECRET=

# ESV Bible API
ESV_API_KEY=

# Database (SQLite for local dev)
DATABASE_URL=file:./prisma/dev.db

# Encryption key for API key storage (32-byte hex string)
ENCRYPTION_KEY=

# Server port
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Node environment
NODE_ENV=development
