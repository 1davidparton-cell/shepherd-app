generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  googleId    String?  @unique
  name        String
  email       String   @unique
  role        String   @default("counselor")
  counselorId String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  counselor User?  @relation("DiscipleTree", fields: [counselorId], references: [id])
  disciples User[] @relation("DiscipleTree")

  settings          AdminSettings?
  assignedHomework  Homework[]          @relation("HomeworkAssignedTo")
  createdHomework   Homework[]          @relation("HomeworkAssignedBy")
  homeworkResponses HomeworkResponse[]
  sessionNotes      SessionNote[]       @relation("SessionNotesCounselor")
  personalChat      PersonalChatSession?
  adminChatSessions ChatSession[]
  scriptureQueries  ScriptureQuery[]
  relationsFrom     UserRelationship[]  @relation("RelFrom")
  relationsTo       UserRelationship[]  @relation("RelTo")
}

model UserRelationship {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  type      String
  createdAt DateTime @default(now())

  from User @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model AdminSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  aiProvider      String  @default("anthropic")
  encryptedApiKey String?
  selectedModel   String?

  user User @relation(fields: [userId], references: [id])
}

model Homework {
  id           String    @id @default(cuid())
  title        String
  scriptureRef String?
  instructions String
  type         String    @default("custom")
  assignedToId String
  assignedById String
  dueDate      DateTime?
  completedAt  DateTime?
  status       String    @default("sent")
  createdAt    DateTime  @default(now())

  assignedTo User               @relation("HomeworkAssignedTo", fields: [assignedToId], references: [id])
  assignedBy User               @relation("HomeworkAssignedBy", fields: [assignedById], references: [id])
  responses  HomeworkResponse[]
}

model HomeworkResponse {
  id           String   @id @default(cuid())
  homeworkId   String
  userId       String
  responseText String
  submittedAt  DateTime @default(now())

  homework Homework @relation(fields: [homeworkId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model SessionNote {
  id          String   @id @default(cuid())
  counselorId String
  subjectId   String?
  content     String
  createdAt   DateTime @default(now())

  counselor User @relation("SessionNotesCounselor", fields: [counselorId], references: [id])
}

model ChatSession {
  id          String   @id @default(cuid())
  counselorId String
  contextId   String?
  messages    String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  counselor User @relation(fields: [counselorId], references: [id])
}

model PersonalChatSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  messages  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ScriptureQuery {
  id             String   @id @default(cuid())
  userId         String
  input          String
  kind           String
  acknowledgment String
  canonical      String
  passages       String
  practicalStep  String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
